# Copy this file to /etc/wol-api.env and fill in a strong random token.
# setup.sh does this automatically (with a generated token) if
# /etc/wol-api.env doesn't already exist.

# Bearer token required for POST /wake requests.
WOL_TOKEN=changeme-generate-a-long-random-token

# Target desktop to wake.
WOL_MAC=50:EB:F6:5C:CE:3E
WOL_BROADCAST=192.168.0.255

# Port the HTTP API listens on.
WOL_PORT=8080
